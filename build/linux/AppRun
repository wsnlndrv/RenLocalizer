#!/bin/bash
# AppRun — Entry point for RenLocalizer AppImage
# This script is called automatically when the .AppImage is executed.

# Determine where the AppImage was mounted
APPDIR="$(dirname "$(readlink -f "$0")")"

# Set library path so PyInstaller's bundled libs are found
export LD_LIBRARY_PATH="${APPDIR}/usr/bin/RenLocalizer:${LD_LIBRARY_PATH}"

# Set Qt plugin path for PyQt6
export QT_PLUGIN_PATH="${APPDIR}/usr/bin/RenLocalizer/PyQt6/Qt6/plugins"
export QML2_IMPORT_PATH="${APPDIR}/usr/bin/RenLocalizer/PyQt6/Qt6/qml"

# Prefer XWayland first on mixed Wayland/X11 sessions unless the user has
# already chosen a Qt platform plugin manually.
if [ -z "${QT_QPA_PLATFORM:-}" ] && [ -z "${RENLOCALIZER_QT_PLATFORM:-}" ]; then
    if [ -n "${DISPLAY:-}" ] && [ -n "${WAYLAND_DISPLAY:-}" ]; then
        export RENLOCALIZER_QT_PLATFORM_HINT="xcb;wayland"
    fi
fi

# Ensure XDG paths are sane
export XDG_DATA_DIRS="${APPDIR}/usr/share:${XDG_DATA_DIRS:-/usr/share}"

# ── Font configuration ──────────────────────────────────────
# Make bundled emoji font (NotoColorEmoji.ttf) discoverable by fontconfig.
# This ensures emoji UI icons render correctly even on minimal distros
# that lack a color emoji font package.
BUNDLED_FONTS="${APPDIR}/usr/bin/RenLocalizer/fonts"
if [ -d "${BUNDLED_FONTS}" ]; then
    FONTCONF_DIR="$(mktemp -d "${XDG_RUNTIME_DIR:-/tmp}/renlocalizer-fonts.XXXXXX" 2>/dev/null || true)"
    if [ -n "${FONTCONF_DIR}" ] && [ -d "${FONTCONF_DIR}" ]; then
        FONTCONF="${FONTCONF_DIR}/fonts.conf"
        cat > "${FONTCONF}" <<EOF
<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "urn:fontconfig:fonts.dtd">
<fontconfig>
  <dir>/usr/share/fonts</dir>
  <dir>/usr/local/share/fonts</dir>
  <dir prefix="xdg">fonts</dir>
  <dir>${BUNDLED_FONTS}</dir>
  <cachedir prefix="xdg">fontconfig</cachedir>
</fontconfig>
EOF
        export FONTCONFIG_FILE="${FONTCONF}"
    fi
fi

# Launch the application
# Pass all command-line arguments through
exec "${APPDIR}/usr/bin/RenLocalizer/RenLocalizer" "$@"
